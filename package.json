{
	"name": "cno-plugin-judicial-interactivity-blocks",
	"version": "1.0.2",
	"description": "Adds custom Gutenberg blocks for the Choctaw Judicial site that use the Interactivity API.",
	"prettier": "@wordpress/prettier-config",
	"browserslist": [
		"extends @wordpress/browserslist-config"
	],
	"author": "Choctaw Nation of Oklahoma",
	"files": [
		"build",
		"inc",
		"README.md",
		"LICENSE",
		"cno-plugin-judicial-interactivity-blocks.php"
	],
	"scripts": {
		"build": "wp-scripts build --blocks-manifest --experimental-modules --webpack-copy-php",
		"lint:css": "npx stylelint '**/*.scss' '**/*.css' --fix --allow-empty-input",
		"lint:js": "npx eslint --fix",
		"packages-update": "wp-scripts packages-update",
		"plugin-zip": "wp-scripts build --blocks-manifest --experimental-modules --webpack-copy-php && wp-scripts plugin-zip",
		"start": "wp-scripts start --blocks-manifest --experimental-modules --webpack-copy-php"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.2",
		"@eslint/eslintrc": "^3.3.3",
		"@wordpress/block-editor": "^15.13.0",
		"@wordpress/blocks": "^15.13.0",
		"@wordpress/components": "^32.2.0",
		"@wordpress/data": "^10.40.0",
		"@wordpress/dom-ready": "^4.40.0",
		"@wordpress/editor": "^14.40.0",
		"@wordpress/element": "^6.40.0",
		"@wordpress/eslint-plugin": "^24.2.0",
		"@wordpress/icons": "^11.7.0",
		"@wordpress/interactivity": "^6.40.0",
		"@wordpress/scripts": "^31.5.0",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-import-resolver-typescript": "^4.4.4",
		"eslint-plugin-react-hooks": "^7.0.1",
		"globals": "^17.3.0",
		"stylelint": "^17.3.0",
		"stylelint-config-standard-scss": "^17.0.0",
		"stylelint-scss": "^7.0.0"
	},
	"overrides": {
		"@wordpress/upload-media": "0.24.0"
	}
}
